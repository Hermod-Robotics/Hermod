<?xml version="1.0"?>
<!--
  Robot URDF/XACRO — Auto-generated by Hermod

  @ai-context: This URDF describes the full kinematic tree of <%= robot.name %>.
               Type: <%= robot.type %>.
               Link origins and joint axes are derived from robot.hardware.yaml.
               Mass/inertia values are placeholders — replace with CAD-derived values.
  @ai-extend: Add custom links, gazebo plugins, or transmission blocks below.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="<%= robot.name.replace(/[^a-zA-Z0-9]/g, '_') %>">

  <!-- ── Materials ── -->
  <material name="base_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>
  <material name="link_grey">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="sensor_blue">
    <color rgba="0.2 0.4 0.8 1"/>
  </material>

<% const isArm = robot.type === 'arm_6dof'; %>

  <!-- ═══════════════════════════════════════ -->
  <!-- Base Link                               -->
  <!-- ═══════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <mass value="<%= isArm ? '5.0' : '3.0' %>"/>
      <inertia ixx="<%= isArm ? '0.5' : '0.2' %>" ixy="0" ixz="0" iyy="<%= isArm ? '0.5' : '0.2' %>" iyz="0" izz="<%= isArm ? '0.3' : '0.2' %>"/>
    </inertial>
    <visual>
      <geometry>
        <box size="<%= isArm ? '0.2 0.2 0.08' : '0.4 0.25 0.15' %>"/>
      </geometry>
      <material name="base_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="<%= isArm ? '0.2 0.2 0.08' : '0.4 0.25 0.15' %>"/>
      </geometry>
    </collision>
  </link>

<% if (isArm) { %>
  <!-- ═══════════════════════════════════════ -->
  <!-- Serial Chain (Manipulator Arm)          -->
  <!-- ═══════════════════════════════════════ -->
<%
  const activeJoints = joints.filter(j => j.type === 'active');
  for (let i = 0; i < activeJoints.length; i++) {
    const joint = activeJoints[i];
    const parent = i === 0 ? 'base_link' : activeJoints[i-1].name;
    const child = joint.name;
    const isWrist = i >= 3;
    const linkLength = isWrist ? 0.08 : 0.25;
    const linkRadius = isWrist ? 0.03 : 0.05;
    const mass = isWrist ? 0.3 : 1.5;
    const zOffset = isWrist ? 0.15 : 0.30;
%>
  <!-- Joint <%= i+1 %>: <%= joint.name %> (Motor: <%= joint.motor %>) -->
  <link name="<%= child %>">
    <inertial>
      <mass value="<%= mass %>"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="<%= linkRadius %>" length="<%= linkLength %>"/>
      </geometry>
      <material name="link_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="<%= linkRadius %>" length="<%= linkLength %>"/>
      </geometry>
    </collision>
  </link>

  <joint name="<%= child %>_joint" type="<%= i < 3 ? 'revolute' : 'revolute' %>">
    <parent link="<%= parent %>"/>
    <child link="<%= child %>"/>
    <origin xyz="0 0 <%= zOffset %>" rpy="0 0 0"/>
    <axis xyz="<%= i % 2 === 0 ? '0 0 1' : '0 1 0' %>"/>
    <limit effort="<%= joint.motorEntry?.mechanical?.peakTorqueNm ?? 10 %>"
           velocity="<%= (joint.motorEntry?.mechanical?.maxSpeedRpm ?? 60) * Math.PI / 30 %>"
           lower="<%= i === 0 ? -3.14 : -2.0 %>"
           upper="<%= i === 0 ? 3.14 : 2.0 %>"/>
  </joint>
<% } %>

<% } else { %>
  <!-- ═══════════════════════════════════════ -->
  <!-- Mobile Base (Wheels)                    -->
  <!-- ═══════════════════════════════════════ -->
<% for (const joint of joints) {
     if (joint.type === 'passive') { %>
  <!-- Passive: <%= joint.name %> -->
  <link name="<%= joint.name %>">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
    </visual>
  </link>
  <joint name="<%= joint.name %>_joint" type="continuous">
    <parent link="base_link"/>
    <child link="<%= joint.name %>"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
<%   } else if (joint.type === 'active') { %>
  <!-- Active: <%= joint.name %> (Motor: <%= joint.motor %>) -->
  <link name="<%= joint.name %>">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </visual>
  </link>
  <joint name="<%= joint.name %>_joint" type="continuous">
    <parent link="base_link"/>
    <child link="<%= joint.name %>"/>
<%   if (joint.role === 'drive' && joint.name.includes('left')) { %>
    <origin xyz="0 0.12 -0.05" rpy="0 0 0"/>
<%   } else if (joint.role === 'drive' && joint.name.includes('right')) { %>
    <origin xyz="0 -0.12 -0.05" rpy="0 0 0"/>
<%   } else if (joint.name.includes('front')) { %>
    <origin xyz="0.15 0 -0.05" rpy="0 0 0"/>
<%   } else { %>
    <origin xyz="-0.15 0 -0.05" rpy="0 0 0"/>
<%   } %>
    <axis xyz="0 1 0"/>
  </joint>
<%   }
   }
} %>

  <!-- ── Sensor Mounts ── -->
<% for (const sensor of sensors) {
     if (!sensor.mount) continue; %>
  <link name="<%= sensor.name %>_mount">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry><box size="0.03 0.03 0.03"/></geometry>
      <material name="sensor_blue"/>
    </visual>
  </link>
  <joint name="<%= sensor.name %>_joint" type="fixed">
    <parent link="<%= isArm ? activeJoints[0].name : 'base_link' %>"/>
    <child link="<%= sensor.name %>_mount"/>
    <origin xyz="<%= sensor.mount.x %> <%= sensor.mount.y %> <%= sensor.mount.z %>"
            rpy="<%= sensor.mount.roll ?? 0 %> <%= sensor.mount.pitch ?? 0 %> <%= sensor.mount.yaw ?? 0 %>"/>
  </joint>
<% } %>

  <!-- ── @ai-extend: Add custom links and joints below ── -->

</robot>
