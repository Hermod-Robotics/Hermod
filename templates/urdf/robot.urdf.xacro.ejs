<?xml version="1.0"?>
<!--
  Robot URDF/XACRO — Auto-generated by Hermod

  @ai-context: This URDF describes the full kinematic tree of the robot.
               Link origins and joint axes are derived from robot.hardware.yaml.
               Sensor mount positions are included as static transforms.
               Mass/inertia values are placeholders — replace with CAD-derived values.
  @ai-extend: Add custom links, gazebo plugins, or transmission blocks below.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="<%= robot.name.replace(/[^a-zA-Z0-9]/g, '_') %>">

  <!-- ── Materials ── -->
  <material name="chassis_grey">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="sensor_blue">
    <color rgba="0.2 0.4 0.8 1"/>
  </material>

  <!-- ── Base Link ── -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>  <!-- TODO: replace with actual mass -->
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.3 0.2 0.15"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.2 0.15"/>
      </geometry>
    </collision>
  </link>

  <!-- ── Wheels ── -->
<% for (const joint of joints) {
     if (joint.type === 'passive') { %>
  <!-- Passive: <%= joint.name %> (caster/omni wheel) -->
  <link name="<%= joint.name %>">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>
  <joint name="<%= joint.name %>_joint" type="continuous">
    <parent link="base_link"/>
    <child link="<%= joint.name %>"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
<%   } else if (joint.type === 'active') { %>
  <!-- Active: <%= joint.name %> (Motor: <%= joint.motor %>) -->
  <link name="<%= joint.name %>">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.06" length="0.03"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>
  <joint name="<%= joint.name %>_joint" type="continuous">
    <parent link="base_link"/>
    <child link="<%= joint.name %>"/>
<%   if (joint.role === 'drive' && joint.name.includes('left')) { %>
    <origin xyz="0 0.12 -0.05" rpy="0 0 0"/>
<%   } else if (joint.role === 'drive' && joint.name.includes('right')) { %>
    <origin xyz="0 -0.12 -0.05" rpy="0 0 0"/>
<%   } else if (joint.name.includes('front')) { %>
    <origin xyz="0.15 0 -0.05" rpy="0 0 0"/>
<%   } else { %>
    <origin xyz="-0.15 0 -0.05" rpy="0 0 0"/>
<%   } %>
    <axis xyz="0 1 0"/>
  </joint>
<%   }
   } %>

  <!-- ── Sensor Mounts ── -->
<% for (const sensor of sensors) {
     if (!sensor.mount) continue; %>
  <link name="<%= sensor.name %>_mount">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <material name="sensor_blue"/>
    </visual>
  </link>
  <joint name="<%= sensor.name %>_joint" type="fixed">
    <parent link="base_link"/>
    <child link="<%= sensor.name %>_mount"/>
    <origin xyz="<%= sensor.mount.x %> <%= sensor.mount.y %> <%= sensor.mount.z %>"
            rpy="<%= sensor.mount.roll ?? 0 %> <%= sensor.mount.pitch ?? 0 %> <%= sensor.mount.yaw ?? 0 %>"/>
  </joint>
<% } %>

  <!-- ── @ai-extend: Add custom links and joints below ── -->

</robot>
