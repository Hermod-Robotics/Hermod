<?xml version="1.0"?>
<!--
  Gazebo World — Auto-generated by Hermod

  @ai-context: Simulation world for <%= robot.name %>.
               Type: <%= robot.type %>.
               Includes ground plane, lighting, and the robot model.
  @ai-extend: Add obstacles, walls, or other environment elements.
-->
<sdf version="1.9">
  <world name="<%= robotName %>_world">

    <!-- ── Environment ── -->
    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- ── Lighting ── -->
    <light type="directional" name="overhead">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>0 0 -1</direction>
    </light>

    <!-- ── Physics ── -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ── Robot Model ── -->
    <model name="<%= robotName %>">
      <pose>0 0 0.1 0 0 0</pose>

      <!-- Base chassis -->
      <link name="base_link">
        <inertial>
          <mass>3.0</mass>
          <inertia>
            <ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.2</iyy><iyz>0</iyz>
            <izz>0.1</izz>
          </inertia>
        </inertial>
        <visual name="chassis_visual">
          <geometry><box><size>0.4 0.25 0.15</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material>
        </visual>
        <collision name="chassis_collision">
          <geometry><box><size>0.4 0.25 0.15</size></box></geometry>
        </collision>
      </link>

<% for (const joint of activeJoints) { %>
      <!-- <%= joint.name %> (Motor: <%= joint.motor %>) -->
      <link name="<%= joint.name %>">
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>0.0005</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0005</iyy><iyz>0</iyz>
            <izz>0.0005</izz>
          </inertia>
        </inertial>
        <visual name="<%= joint.name %>_visual">
          <geometry><cylinder radius="0.06" length="0.03"/></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
        <collision name="<%= joint.name %>_collision">
          <geometry><cylinder radius="0.06" length="0.03"/></geometry>
        </collision>
      </link>

      <joint name="<%= joint.name %>_joint" type="revolute">
        <parent>base_link</parent>
        <child><%= joint.name %></child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1e+16</lower>
            <upper>1e+16</upper>
          </limit>
          <dynamics>
            <damping>0.1</damping>
            <friction>0.01</friction>
          </dynamics>
        </axis>
      </joint>
<% } %>

<% if (sensors.some(s => s.model?.startsWith('rplidar'))) { %>
      <!-- LiDAR sensor -->
      <link name="lidar_link">
        <pose>0.15 0 0.30 0 0 0</pose>
        <inertial>
          <mass>0.19</mass>
          <inertia>
            <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0001</iyy><iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="lidar_visual">
          <geometry><cylinder radius="0.04" length="0.04"/></geometry>
          <material><ambient>0.2 0.4 0.8 1</ambient></material>
        </visual>
        <sensor name="lidar_sensor" type="ray">
          <pose>0 0 0 0 0 0</pose>
          <ray>
            <scan><horizontal><samples>360</samples><resolution>1</resolution>
              <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
            </horizontal></scan>
            <range><min>0.2</min><max>25</max><resolution>0.01</resolution></range>
          </ray>
          <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
            <ros><namespace><%= rosNs %></namespace></ros>
            <topicName>scan</topicName>
            <frameName>lidar_link</frameName>
          </plugin>
        </sensor>
      </link>
      <joint name="lidar_joint" type="fixed">
        <parent>base_link</parent>
        <child>lidar_link</child>
      </joint>
<% } %>

<% if (sensors.some(s => s.model === 'bmi088')) { %>
      <!-- IMU sensor -->
      <link name="imu_link">
        <pose>0 0 0.05 0 0 0</pose>
        <sensor name="imu_sensor" type="imu">
          <imu>
            <angular_velocity><x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x></angular_velocity>
            <linear_acceleration><x><noise type="gaussian"><mean>0</mean><stddev>0.1</stddev></noise></x></linear_acceleration>
          </imu>
          <plugin name="imu_controller"
                  filename="libgazebo_ros_imu_sensor.so">
            <ros><namespace><%= rosNs %></namespace></ros>
            <topicName>imu</topicName>
            <frameName>imu_link</frameName>
          </plugin>
        </sensor>
      </link>
      <joint name="imu_joint" type="fixed">
        <parent>base_link</parent>
        <child>imu_link</child>
      </joint>
<% } %>

      <!-- Differential Drive Plugin -->
      <plugin name="diff_drive"
              filename="libgazebo_ros_diff_drive.so">
        <ros><namespace><%= rosNs %></namespace></ros>

        <!-- Wheel joints -->
        <left_joint><%= activeJoints.find(j => j.name.includes('left') && j.name.includes('front'))?.name ?? activeJoints.find(j => j.name.includes('left'))?.name %>_joint</left_joint>
        <right_joint><%= activeJoints.find(j => j.name.includes('right') && j.name.includes('front'))?.name ?? activeJoints.find(j => j.name.includes('right'))?.name %>_joint</right_joint>
        <left_joint><%= activeJoints.find(j => j.name.includes('left') && j.name.includes('rear'))?.name %>_joint</left_joint>
        <right_joint><%= activeJoints.find(j => j.name.includes('right') && j.name.includes('rear'))?.name %>_joint</right_joint>

        <!-- Kinematics -->
        <wheel_separation>0.24</wheel_separation>
        <wheel_diameter>0.12</wheel_diameter>
        <max_wheel_torque>5</max_wheel_torque>
        <max_wheel_acceleration>10</max_wheel_acceleration>

        <!-- Odometry -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>false</publish_wheel_tf>

        <!-- Command topic -->
        <command_topic>cmd_vel</command_topic>
        <odometry_topic>odom</odometry_topic>
      </plugin>

    </model>

  </world>
</sdf>
