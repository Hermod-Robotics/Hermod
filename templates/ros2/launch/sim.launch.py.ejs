"""
Simulation Launch — Auto-generated by Hermod

@ai-context: Launches Gazebo with the robot world, spawns the robot model,
             starts ros2_control, and brings up sensor drivers.
@ai-extend: Add navigation stack, RViz config, or custom controllers.

ROS Version: <%= ros.version %>
Namespace:   <%= rosNs %>
"""

import os
from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch.substitutions import LaunchConfiguration
from launch_ros.actions import Node
from ament_index_python.packages import get_package_share_directory


def generate_launch_description():
    ns = "<%= rosNs %>"
    world_file = os.path.join(
        get_package_share_directory("<%= pkgName %>_bringup"),
        "worlds", "<%= robotName %>.sdf"
    )
    urdf_file = os.path.join(
        get_package_share_directory("<%= pkgName %>_description"),
        "urdf", "<%= robotName %>.urdf.xacro"
    )

    # ── Gazebo ──
    gazebo = IncludeLaunchDescription(
        PythonLaunchDescriptionSource([
            os.path.join(
                get_package_share_directory("gazebo_ros"),
                "launch", "gazebo.launch.py"
            )
        ]),
        launch_arguments={
            "world": world_file,
            "verbose": "false",
        }.items(),
    )

    # ── Robot State Publisher ──
    robot_state_pub = Node(
        package="robot_state_publisher",
        executable="robot_state_publisher",
        namespace=ns,
        parameters=[{
            "robot_description": ["xacro ", urdf_file],
            "use_sim_time": True,
        }],
        output="screen",
    )

    # ── Spawn Robot ──
    spawn_robot = Node(
        package="gazebo_ros",
        executable="spawn_entity.py",
        namespace=ns,
        arguments=[
            "-entity", "<%= robotName %>",
            "-topic", "robot_description",
            "-x", "0.0", "-y", "0.0", "-z", "0.1",
        ],
        output="screen",
    )

    # ── Controller Manager ──
    controller_manager = Node(
        package="controller_manager",
        executable="ros2_control_node",
        namespace=ns,
        parameters=[{
            "robot_description": ["xacro ", urdf_file],
            "use_sim_time": True,
        }],
        output="screen",
    )

    # ── Diff Drive Controller ──
    diff_drive_spawner = Node(
        package="controller_manager",
        executable="spawner",
        namespace=ns,
        arguments=["diff_drive_controller"],
        output="screen",
    )

    # ── Joint State Broadcaster ──
    joint_state_spawner = Node(
        package="controller_manager",
        executable="spawner",
        namespace=ns,
        arguments=["joint_state_broadcaster"],
        output="screen",
    )

    return LaunchDescription([
        gazebo,
        robot_state_pub,
        spawn_robot,
        controller_manager,
        joint_state_spawner,
        diff_drive_spawner,
    ])
