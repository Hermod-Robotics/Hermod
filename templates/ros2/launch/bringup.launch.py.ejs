"""
Robot Bringup Launch — Auto-generated by Hermod

@ai-context: Launches all core nodes for <%= robot.name %>.
             Includes ros2_control, sensor drivers, and state publishers.
@ai-extend: Add custom nodes (navigation, perception, etc.) below.

ROS Version: <%= ros?.version ?? 'humble' %>
Namespace:   <%= ros?.namespace ?? '' %>
"""

from launch import LaunchDescription
from launch_ros.actions import Node
from launch.actions import DeclareLaunchArgument


def generate_launch_description():
    ns = "<%= ros?.namespace ?? '' %>"

    # ── ros2_control ──
    controller_manager = Node(
        package="controller_manager",
        executable="ros2_control_node",
        namespace=ns,
        parameters=["$(find-pkg-share <%= (ros?.namespace ?? 'hermod_robot').replace(/-/g, '_') %>_bringup)/config/controllers.yaml"],
        output="screen",
    )

    # ── Sensor Drivers ──
    nodes = [controller_manager]

<% for (const sensor of sensors) { %>
<% if (sensor.model?.startsWith('rplidar')) { %>
    # <%= sensor.name %> — RPLIDAR driver
    nodes.append(Node(
        package="rplidar_ros",
        executable="rplidar_composition",
        namespace=ns,
        name="<%= sensor.name %>",
        parameters=[{
            "serial_port": "<%= sensor.port %>",
            "serial_baudrate": <%= sensor.baudrate ?? 256000 %>,
            "frame_id": "<%= sensor.name %>_mount",
            "inverted": False,
            "angle_compensate": True,
        }],
        output="screen",
    ))
<% } else { %>
    # TODO: Add driver node for <%= sensor.name %> (<%= sensor.model %>)
<% } %>
<% } %>

    return LaunchDescription(nodes)
