#pragma once

#include "main.h"

/* CAN peripheral base addresses */
<% for (let i = 0; i < mcu.peripherals.can; i++) { %>
#define CAN_PERIPH_<%= i + 1 %>    CAN<%= i + 1 %>
<% } %>

/* CAN baudrate (from knowledge base) */
<% const canMotor = activeJoints.find(j => j.motorEntry?.control.protocol === 'CAN'); %>
#define CAN_BAUDRATE    <%= canMotor?.motorEntry?.control.canBaudrate ?? 1000000 %>

/* ── Motor CAN ID Map ── */
<% for (const joint of activeJoints) { %>
<% if (joint.motorEntry?.control.protocol === 'CAN') { %>
/**
 * <%= joint.name %>
 * Motor: <%= joint.motorEntry.id %>
 * @ai-context: CAN ID 0x<%= joint.canId?.toString(16) ?? '???' %>
 */
#define MOTOR_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_CAN_ID    0x<%= joint.canId?.toString(16) ?? '???' %>
<% } %>
<% } %>

/* ── CAN Message Structs ── */

/** Motor control command (host → motor) */
typedef struct __attribute__((packed)) {
    int16_t current_iq;     /**< Torque current setpoint (mA) */
    int16_t current_id;     /**< Field-weakening current (mA), usually 0 */
} MotorCmd_t;

/** Motor feedback frame (motor → host) */
typedef struct __attribute__((packed)) {
    uint16_t angle_raw;     /**< Raw encoder angle (0–8191) */
    int16_t  speed_rpm;     /**< Rotor speed (RPM) */
    int16_t  current_iq;    /**< Actual torque current (mA) */
    uint8_t  temp_c;        /**< Motor winding temperature (°C) */
} MotorFb_t;

