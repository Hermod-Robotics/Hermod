#pragma once

#include <stdint.h>

/* ── Motor Safety Limits ── */
<% for (const joint of activeJoints) {
     const m = joint.motorEntry;
     if (!m) continue; %>
/**
 * <%= joint.name %> — <%= m.id %>
 *
 * @ai-lock: Max current <%= m.safety.maxCurrentA %>A (driver chip physical limit)
 * @ai-lock: Max temperature <%= m.safety.maxTempC %>°C (magnet demagnetization threshold)
 * @ai-lock: Max speed <%= m.safety.maxSpeedRpm %> RPM (mechanical limit)
 */
#define SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_MAX_CURRENT_A   <%= m.safety.maxCurrentA %>f
#define SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_MAX_TEMP_C      <%= m.safety.maxTempC %>f
#define SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_MAX_SPEED_RPM   <%= m.safety.maxSpeedRpm %>f
<% if (m.safety.currentLimitSoftA) { %>
#define SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_SOFT_CURRENT_A  <%= m.safety.currentLimitSoftA %>f  /* @ai-critical */
<% } %>
<% } %>

/* ── Global Safety ── */

/** System watchdog timeout — triggers emergency stop on motor comm loss */
<% const wdTimeout = Math.max(...activeJoints.map(j => j.motorEntry?.safety.watchdogTimeoutMs ?? 100)); %>
#define SAFE_WATCHDOG_TIMEOUT_MS    <%= wdTimeout %>  /* @ai-lock */

/** Emergency stop deceleration ramp (ms from full speed to zero) */
#define SAFE_ESTOP_RAMP_MS          10    /* @ai-lock */

/** Soft stop deceleration ramp */
#define SAFE_SOFT_STOP_RAMP_MS      200   /* @ai-critical */

/* ── Power Safety ── */
#define SAFE_BATTERY_MIN_V          <%= power.voltageRange[0] %>.0f
#define SAFE_BATTERY_MAX_V          <%= power.voltageRange[1] %>.0f

