/**
 * Motor FOC Control — Auto-generated by Hermod
 *
 * @ai-context: Field-Oriented Control implementation for all active joints.
 *              PID parameters are knowledge base defaults — tune on real hardware.
 * @ai-critical: PID gains marked @ai-critical require human confirmation to modify.
 * @ai-extend: Add custom control modes (e.g. impedance control) below.
 */

#include "motor_foc.h"
#include "can_config.h"
#include "safety/limits.h"

/* ── Per-Motor PID Configurations ── */
<% for (const joint of activeJoints) {
     const m = joint.motorEntry;
     if (!m) continue;
     const pid = m.pidDefaults ?? {}; %>
/**
 * <%= joint.name %> — <%= m.id %> FOC Controller
 *
 * Pole pairs: <%= m.electrical.polePairs %> (hardware parameter)
 * Reduction ratio: <%= m.mechanical.reductionRatio %>:1
 *
 * @ai-critical: Current loop gains — modify only with torque sensor verification
 * @ai-critical: Speed loop gains — modify only with encoder feedback verification
 */
static const FocController_t foc_<%= joint.name.replace(/[^a-zA-Z0-9]/g, '_') %> = {
    .pole_pairs        = <%= m.electrical.polePairs %>,     /* @ai-lock */
    .reduction_ratio   = <%= m.mechanical.reductionRatio %>f,   /* @ai-lock */
    <% if (pid.currentLoop) { %>
    .current_kp        = <%= pid.currentLoop.kp %>f,   /* @ai-critical */
    .current_ki        = <%= pid.currentLoop.ki %>f,   /* @ai-critical */
    .current_kd        = <%= pid.currentLoop.kd %>f,   /* @ai-critical */
    <% } %>
    <% if (pid.speedLoop) { %>
    .speed_kp          = <%= pid.speedLoop.kp %>f,   /* @ai-critical */
    .speed_ki          = <%= pid.speedLoop.ki %>f,   /* @ai-critical */
    .speed_kd          = <%= pid.speedLoop.kd %>f,   /* @ai-critical */
    <% } %>
    <% if (pid.positionLoop) { %>
    .position_kp       = <%= pid.positionLoop.kp %>f,   /* @ai-critical */
    .position_ki       = <%= pid.positionLoop.ki %>f,   /* @ai-critical */
    .position_kd       = <%= pid.positionLoop.kd %>f,   /* @ai-critical */
    <% } %>
    .max_current_a     = SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_MAX_CURRENT_A,
    .soft_current_a    = SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_SOFT_CURRENT_A,
    .max_temp_c        = SAFE_<%= joint.name.toUpperCase().replace(/[^A-Z0-9]/g, '_') %>_MAX_TEMP_C,
};
<% } %>

/* ── Controller Registry ── */
#define NUM_MOTORS  <%= activeJoints.length %>

static const FocController_t* g_controllers[NUM_MOTORS] = {
<% for (const joint of activeJoints) { %>
    &foc_<%= joint.name.replace(/[^a-zA-Z0-9]/g, '_') %>,
<% } %>
};

/* ── @ai-extend: Add custom control logic below ── */
