{
  "name": "@hermod/engine",
  "version": "0.0.0",
  "private": true,
  "description": "Core engine — types, validation, and code generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
