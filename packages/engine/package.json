    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
